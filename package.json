{
  "name": "finance",
  "version": "1.0.0",
  "description": "FinOpenPOS Professional Management System",
  "author": "Frank Borromeo",
  "private": true,
  "engines": {
    "node": ">=18.0.0 || >=20.0.0 || >=24.0.0"
  },
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron-dev": "electron .",
    "build-exe": "npm run build && npx electron-builder",
    "build-win": "npm run build && npx electron-builder --win"
  },
  "build": {
    "appId": "com.finopenpos.app",
    "productName": "FinOpenPOS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}_Setup.exe"
    },
    "portable": {
      "artifactName": "${productName}_Standalone.exe"
    },
    "files": [
      "main.js",
      "unauthorized.html",
      "traditional_receipt.html",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!data/**/*",
      "!dist/**/*",
      "!build_pack/**/*"
    ],
    "extraResources": [
      ".env"
    ],
    "asar": true,
    "asarUnpack": [
      ".next/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.414.0",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.30",
    "next-electron-server": "^1.0.0",
    "pouchdb": "^9.0.0",
    "pouchdb-find": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pouchdb": "^6.4.2",
    "@types/pouchdb-find": "^7.3.3",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
